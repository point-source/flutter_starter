#!/usr/bin/env bash
# Pre-commit hook: auto-fixes formatting, runs codegen, and validates.
# Formatting fixes are staged automatically. If codegen produces changes,
# the commit is aborted so you can review the updates and commit again.
# Also blocked by analysis errors or test failures.
#
# Skip with: git commit --no-verify
#
# Install with: git config core.hooksPath .githooks

set -euo pipefail

REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

echo "Running CI checks before commit (auto-fixing where possible)..."
echo "(skip with: git commit --no-verify)"
echo ""

exec "$REPO_ROOT/scripts/ci-check.sh"
